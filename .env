# WealthPilot v3 — environment config  (NEVER commit this file)

# ── Alpaca Paper Trading keys ────────────────────────────────────────────────
# Get from: app.alpaca.markets → top-left dropdown → "Paper Trading" → API Keys
# IMPORTANT: Paper keys are DIFFERENT from live keys. They live on different screens.
ALPACA_PAPER_KEY=PK2S4DTZU44AERXREK7PMGJGQP
ALPACA_PAPER_SECRET=EkMFawcndffMdokUqx3wXSeaLQ6oHRW4c3zr9LJqe8uF

# ── Alpaca Live Trading keys ─────────────────────────────────────────────────
# Get from: app.alpaca.markets → (make sure you're on Live, not Paper) → API Keys
# Fill these in when you're ready to go live. Set mode='live' in Settings.
ALPACA_LIVE_KEY=your_live_key_here
ALPACA_LIVE_SECRET=your_live_secret_here

# WealthPilot reads ALPACA_PAPER_KEY/SECRET when mode='paper'
# and ALPACA_LIVE_KEY/SECRET when mode='live'.
# Both sets can live in this file simultaneously — switching modes is instant.

